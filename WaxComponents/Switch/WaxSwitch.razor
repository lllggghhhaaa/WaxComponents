@using LucideBlazor
@using WaxComponents.Utils

@inherits WaxComponent

<label class="@LabelClassCss" style="@Style" @attributes="AdditionalAttributes">
    <button
        type="button"
        role="switch"
        aria-checked="@Value.ToString().ToLowerInvariant()"
        disabled="@Disabled"
        @onclick="HandleClick"
        class="@TrackClassCss">
        <span class="@ThumbClassCss">
            @if (Value)
            {
                <LucideIcon Size="10" Name="check" ClassName="text-primary" StrokeWidth="3" />
            }
        </span>
    </button>
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="text-sm font-medium text-foreground">@Label</span>
    }
</label>

@code {
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool Disabled { get; set; }
    
    [Parameter] public string TrackClass { get; set; } = string.Empty;

    [Parameter] public string ThumbClass { get; set; } = string.Empty;

    private async Task HandleClick()
    {
        if (Disabled) return;

        Value = !Value;
        await ValueChanged.InvokeAsync(Value);
    }

    private string LabelClassCss =>
        "inline-flex items-center gap-3"
            .MergeClass(
                Disabled ? "cursor-not-allowed opacity-40" : "cursor-pointer",
                Class);

    private string TrackClassCss =>
        "relative w-14 h-7 rounded-full transition-all duration-300 flex-shrink-0"
            .MergeClass(
                Value ? "bg-primary" : "bg-switch-background",
                Disabled ? "pointer-events-none" : string.Empty,
                TrackClass);

    private string ThumbClassCss =>
        "absolute top-1 w-5 h-5 rounded-full shadow-sm transition-all duration-300 flex items-center justify-center"
            .MergeClass(
                Value ? "left-8 bg-primary-foreground" : "left-1 bg-background",
                ThumbClass);

}
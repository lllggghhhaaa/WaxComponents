@using LucideBlazor
@using WaxComponents.Utils

<label class="@LabelClass">
    <button
        type="button"
        role="switch"
        aria-checked="@Checked.ToString().ToLowerInvariant()"
        disabled="@Disabled"
        @onclick="HandleClick"
        class="@TrackClass">
        <span class="@ThumbClass">
            @if (Checked)
            {
                <LucideIcon Size="10" Name="check" ClassName="text-primary" StrokeWidth="3" />
            }
        </span>
    </button>
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="text-sm font-medium text-foreground">@Label</span>
    }
</label>

@code {
    [Parameter] public bool Checked { get; set; }
    [Parameter] public EventCallback<bool> CheckedChanged { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private async Task HandleClick()
    {
        if (Disabled) return;

        Checked = !Checked;
        await CheckedChanged.InvokeAsync(Checked);
    }

    private string LabelClass =>
        "inline-flex items-center gap-3"
            .Merge(
                Disabled ? "cursor-not-allowed opacity-40" : "cursor-pointer");

    private string TrackClass =>
        "relative w-14 h-7 rounded-full transition-all duration-300 flex-shrink-0"
            .Merge(
                Checked ? "bg-primary" : "bg-switch-background",
                Disabled ? "pointer-events-none" : string.Empty);

    private string ThumbClass =>
        "absolute top-1 w-5 h-5 rounded-full shadow-sm transition-all duration-300 flex items-center justify-center"
            .Merge(
                Checked ? "left-8 bg-primary-foreground" : "left-1 bg-background");

}
@using WaxComponents.Utils

@inherits WaxComponent

<div class="@CssClass" style="@Style" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public WaxCardVariant Variant { get; set; } = WaxCardVariant.Elevated;
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private const string Base = "rounded-3xl p-6 transition-all duration-300";

    private string VariantClass => Variant switch
    {
        WaxCardVariant.Elevated => "bg-card shadow-md shadow-black/8 hover:shadow-xl hover:shadow-black/12 hover:-translate-y-0.5",
        WaxCardVariant.Filled => "bg-muted",
        WaxCardVariant.Outlined => "bg-background border-2 border-border",
        _ => throw new ArgumentOutOfRangeException(nameof(Variant))
    };

    private string CssClass => Base.MergeClass(VariantClass, Class);
}
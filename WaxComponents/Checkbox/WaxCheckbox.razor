@using LucideBlazor
@using WaxComponents.Utils

@inherits WaxComponent

<label class="@LabelClass" style="@Style" @attributes="AdditionalAttributes">
    <button
        type="button"
        role="checkbox"
        aria-checked="@AriaChecked"
        disabled="@Disabled"
        @onclick="HandleClick"
        class="@BoxClass group">
        <span class="@MarkClass" aria-hidden="true">
            <span class="w-2.5 h-0.5 bg-primary-foreground rounded-full"></span>
        </span>
        <span class="@CheckWrapperClass" aria-hidden="true">
            <LucideIcon Size="12" Name="check" StrokeWidth="3" />
        </span>
    </button>
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="text-sm font-medium text-foreground">@Label</span>
    }
</label>

@code {
    [Parameter] public bool Value { get; set; }
    [Parameter] public EventCallback<bool> ValueChanged { get; set; }

    [Parameter] public bool Indeterminate { get; set; }

    [Parameter] public string? Label { get; set; }
    [Parameter] public bool Disabled { get; set; }

    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }

    private async Task HandleClick(MouseEventArgs e)
    {
        if (Disabled) return;

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(e);

        await SetValueAsync(!Value);
    }

    public async Task SetValueAsync(bool value)
    {
        if (Value == value) return;
        Value = value;
        await ValueChanged.InvokeAsync(Value);
        StateHasChanged();
    }

    public Task CheckAsync() => SetValueAsync(true);
    public Task UncheckAsync() => SetValueAsync(false);
    public Task ToggleAsync() => SetValueAsync(!Value);


    private string AriaChecked => Indeterminate ? "mixed" : Value.ToString().ToLowerInvariant();

    private string LabelClass =>
        "inline-flex items-center gap-3 group"
            .MergeClass(Disabled ? "cursor-not-allowed opacity-40" : "cursor-pointer",
                Class);

    private string BoxClass =>
        "relative w-5 h-5 rounded-md border-2 transition-all duration-200 flex items-center justify-center flex-shrink-0"
            .MergeClass(Value || Indeterminate
                    ? "bg-primary border-primary"
                    : "border-border bg-background group-hover:border-primary/50",
                Disabled ? "pointer-events-none" : string.Empty);

    private string MarkClass =>
        "absolute inset-0 flex items-center justify-center transition-opacity duration-150"
            .MergeClass(Indeterminate ? "opacity-100" : "opacity-0");

    private string CheckWrapperClass =>
        "absolute inset-0 flex items-center justify-center text-primary-foreground transition-opacity duration-150"
            .MergeClass(Value && !Indeterminate ? "opacity-100" : "opacity-0");

}
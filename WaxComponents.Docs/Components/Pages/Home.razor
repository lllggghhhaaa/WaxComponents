@page "/"
@rendermode InteractiveServer
@using LucideBlazor
@using WaxComponents.Accordion
@using WaxComponents.Badge
@using WaxComponents.Button
@using WaxComponents.Card
@using WaxComponents.Checkbox
@using WaxComponents.Chip
@using WaxComponents.Fab
@using WaxComponents.Progress
@using WaxComponents.Services.Theme
@using WaxComponents.Switch
@using WaxComponents.Tabs
@using WaxComponents.TextField

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

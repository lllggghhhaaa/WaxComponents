<div class="space-y-8">

    <!-- Filter Chips -->
    <div class="p-6 rounded-3xl bg-card border border-border">
        <h3 class="font-semibold text-foreground mb-1">
            Filter Chips
        </h3>

        <p class="text-sm text-muted-foreground mb-4">
            Toggle-select from a set of mutually inclusive options.
        </p>

        <div class="flex flex-wrap gap-2">
            @foreach (var chip in FilterChips)
            {
                <WaxChip
                    Selected="@FilterSelected.Contains(chip)"
                    SelectedChanged="@(v => ToggleFilter(chip, v))">
                    @chip
                </WaxChip>
            }
        </div>
    </div>

    <!-- Suggestion Chips -->
    <div class="p-6 rounded-3xl bg-card border border-border">
        <h3 class="font-semibold text-foreground mb-1">
            Suggestion Chips
        </h3>

        <p class="text-sm text-muted-foreground mb-4">
            Tap to select a suggestion.
        </p>

        <div class="flex flex-wrap gap-2">
            @foreach (var chip in Suggestions)
            {
                <WaxChip
                    Variant="WaxChipVariant.Suggestion"
                    Selected="@(Suggestion == chip)"
                    SelectedChanged="@(v => SelectSuggestion(chip, v))">
                    @chip
                </WaxChip>
            }
        </div>
    </div>

    <!-- Input Chips -->
    <div class="p-6 rounded-3xl bg-card border border-border">
        <h3 class="font-semibold text-foreground mb-1">
            Input Chips
        </h3>

        <p class="text-sm text-muted-foreground mb-4">
            Dismissable tokens.
        </p>

        <div class="flex flex-wrap gap-2">
            @foreach (var chip in InputChipList)
            {
                <WaxChip
                    Variant="WaxChipVariant.Input"
                    Selected="true"
                    OnRemove="@(_ => RemoveChip(chip))">
                    @chip
                </WaxChip>
            }

            @if (InputChipList.Count < InputChips.Count)
            {
                <button class="text-xs text-primary underline underline-offset-2"
                        @onclick="ResetInputChips">
                    Reset
                </button>
            }
        </div>
    </div>
</div>

<div>
    <h1>Text Fields</h1>
    <WaxTextField Placeholder="Placeholder" Label="Email" @bind-Value="email" Variant="WaxFieldVariant.Filled">
        <Icon>
            <LucideIcon Size="16" Name="mail" />
        </Icon>
    </WaxTextField>

    <WaxTextField Label="Password"
                  Placeholder="Placeholder"
                  @bind-Value="password"
                  Variant="WaxFieldVariant.Outlined" />
</div>

<div>
    <h1>Switch</h1>

    <WaxCard>
        <WaxSwitch Checked="@(Theme.CurrentTheme == ThemeMode.Dark)" CheckedChanged="DarkMode" Label="Dark mode" />
        <WaxSwitch />
    </WaxCard>
    
    <WaxCard>
        <WaxCheckbox
            Checked="AllChecked"
            Indeterminate="IsPartial"
            Label="Select all"
            CheckedChanged="SelectAll" />

        <WaxCheckbox @bind-Checked="_notifyMorning" Label="Notify on morning" />
        <WaxCheckbox @bind-Checked="_agreed" Label="I agree" />

        <WaxCheckbox @ref="_checkboxRef" @bind-Checked="_agreedRef" Label="I agree (ref)" />
        <WaxButton OnClick="@(() => _checkboxRef.UncheckAsync())" Size="WaxButtonSize.Small" Variant="WaxButtonVariant.Text">
            <Text>Reset</Text>
        </WaxButton>
    </WaxCard>
</div>

<div>
    <h1>FAB</h1>
    <WaxCard>
        <WaxFab Variant="WaxFabVariant.Primary" Size="WaxFabSize.Medium" Icon="leaf">
            Add
        </WaxFab>
        <WaxFab Variant="WaxFabVariant.Surface" Size="WaxFabSize.Large" Icon="leaf" />
        <WaxFab Variant="WaxFabVariant.Surface" Size="WaxFabSize.Small" Icon="leaf" />
        <WaxFab Variant="WaxFabVariant.Secondary" Size="WaxFabSize.Small" Icon="leaf" />
        <WaxFab Variant="WaxFabVariant.Tertiary" Size="WaxFabSize.Small" Icon="leaf" />
    </WaxCard>
</div>

<div>
    <h1>Badge</h1>
    <WaxBadge Variant="WaxBadgeVariant.Primary">Primary</WaxBadge>
    <WaxBadge Variant="WaxBadgeVariant.Secondary">Secondary</WaxBadge>
    <WaxBadge Variant="WaxBadgeVariant.Accent">Accent</WaxBadge>
    <WaxBadge Variant="WaxBadgeVariant.Muted">Muted</WaxBadge>
</div>

<div>
    <h1>Progress</h1>
    <WaxCard>
        <WaxProgressBar Variant="WaxProgressBarVariant.Primary" Value="20" Class="my-1" />
        <WaxProgressBar Variant="WaxProgressBarVariant.Secondary" Value="30" Class="my-1" />
        <WaxProgressBar Variant="WaxProgressBarVariant.Accent" Value="45" Class="my-1" />
        <WaxProgressBar Variant="WaxProgressBarVariant.Muted" Value="60" Class="my-1" />
    </WaxCard>
</div>

<WaxTab Variant="WaxTabVariant.Primary" Tabs="_tabs" />
<WaxTab Variant="WaxTabVariant.Secondary" Tabs="_tabs" />

@code {

    private List<WaxTab.TabItem> _tabs =
    [
        new("Overview", Content: @<div>Conteúdo da aba 1</div>),
        new("Settings", Content: @<div>Conteúdo da aba 2</div>, Icon: @<SettingsIcon/>)
    ];
    
    private bool _notifyMorning = true;
    private bool _agreed;
    
    private string email = "";
    private string password = "";

    private bool AllChecked => _notifyMorning && _agreed;
    private bool IsPartial => (_notifyMorning || _agreed) && !AllChecked;

    private void SelectAll(bool check)
    {
        _notifyMorning = check;
        _agreed = check;
    }

    private WaxCheckbox _checkboxRef = default!;
    private bool _agreedRef;

    private List<WaxAccordionItemData> _accordionItemList =
    [
        new()
        {
            Title = "Title 1",
            Body = (MarkupString)"First <strong>item</strong>",
            Icon = @<LucideIcon Size="16" Name="leaf" />
        },
        new()
        {
            Title = "Title 2",
            Body = (MarkupString)"Second item"
        }
    ];
    
    
    private List<string> FilterChips =
    [
        "Coffee",
        "Tea",
        "Juice",
        "Milk"
    ];

    private HashSet<string> FilterSelected = [];

    private void ToggleFilter(string chip, bool selected)
    {
        if (selected)
            FilterSelected.Add(chip);
        else
            FilterSelected.Remove(chip);
    }

    // -------------------------

    private List<string> Suggestions =
    [
        "Design",
        "Blazor",
        "AI",
        "Tailwind"
    ];

    private string? Suggestion;

    private void SelectSuggestion(string chip, bool selected)
    {
        Suggestion = selected ? chip : null;
    }

    // -------------------------

    private List<string> InputChips =
    [
        "C#",
        ".NET",
        "Tailwind",
        "Blazor"
    ];

    private List<string> InputChipList = [];

    protected override void OnInitialized()
    {
        InputChipList = InputChips.ToList();
        Theme.ThemeChanged += OnThemeChanged;
    }

    private void OnThemeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Theme.ThemeChanged -= OnThemeChanged;
    }

    private void RemoveChip(string chip)
    {
        InputChipList.Remove(chip);
    }

    private void ResetInputChips()
    {
        InputChipList = InputChips.ToList();
    }

    private async Task DarkMode(bool value)
    {
        await Theme.SetThemeAsync(value ? ThemeMode.Dark : ThemeMode.Light);
    }

}
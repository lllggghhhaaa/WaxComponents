@rendermode InteractiveServer
@implements IDisposable
@inject IThemeService Theme
@using LucideBlazor
@using WaxComponents.Badge
@using WaxComponents.Navigation
@using WaxComponents.Services.Theme
@using WaxComponents.Switch
@using WaxComponents.Theme
@inherits LayoutComponentBase

<div class="page">
    <WaxSidebar Groups="_groups">
        <Header>
            <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 rounded-2xl bg-primary flex items-center justify-center">
                    <LucideIcon Name="coffee" Size="18" ClassName="text-primary-foreground" />
                </div>
                <div>
                    <p class="font-display font-semibold text-foreground leading-tight">Wax Components</p>
                    <p class="text-xs text-muted-foreground">.</p>
                </div>
            </div>
            <WaxBadge Color="WaxColor.Muted">v1.0.0</WaxBadge>
        </Header>

        <Footer>
            <div class="flex items-center justify-between px-2">
                <span class="text-sm text-muted-foreground">Dark mode</span>
                <WaxSwitch @bind-Value="_darkMode" />
            </div>
        </Footer>
    </WaxSidebar>

    <main>
        <article class="px-6 py-8 max-w-5xl mx-auto w-full">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _darkMode;

    private List<WaxSidebarGroup> _groups =
    [
        new("Foundations",
        [
            new WaxSidebarItem("colors", "Colors", "palette"),
            new WaxSidebarItem("typography", "Typography", "type"),
        ]),
        new("Components",
        [
            new WaxSidebarItem("buttons", "Buttons", "square")
        ]),
        new("Infinity", Enumerable.Repeat(new WaxSidebarItem("colors", "Colors", "palette"), 20).ToList() )
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Theme.ThemeChanged += OnThemeChanged;

            await Theme.InitializeAsync();

            StateHasChanged();
        }
    }

    void OnThemeChanged()
    {
        Console.WriteLine("Theme changed");
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Theme.ThemeChanged -= OnThemeChanged;
    }
}